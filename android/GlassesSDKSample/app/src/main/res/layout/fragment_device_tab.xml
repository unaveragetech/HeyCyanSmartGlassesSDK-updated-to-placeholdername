<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Find and pair your glasses"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_scan_bt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan Bluetooth Devices"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_check_bt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Check Bluetooth Status"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="?attr/colorSecondary"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_open_pairing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open full pairing flow"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="?attr/colorPrimaryVariant"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btn_skip_pairing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue without pairing"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="?attr/colorAccent"
        android:textColor="@android:color/white" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_devices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:overScrollMode="always" />

    <TextView
        android:id="@+id/tv_bt_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bluetooth status"
        android:textColor="@android:color/darker_gray"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_device_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press Scan for nearby devices. Use pairing menu for new devices."
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

</LinearLayout>